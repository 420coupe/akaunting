# =============================================================================
# Akaunting — Docker environment template
# Copy this to .env and fill in all values marked with <CHANGE_ME>
# DO NOT commit .env to version control
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Akaunting
APP_ENV=production
APP_DEBUG=false

# Generate once with: php artisan key:generate --show
# The entrypoint will auto-generate on first boot if left empty,
# but you MUST then persist the printed key here for subsequent restarts.
APP_KEY=

# Your public-facing URL (as configured in Nginx Proxy Manager)
APP_URL=https://your-domain.com

APP_LOCALE=en-US
APP_SCHEDULE_TIME="12:00"

# Set to true AFTER the first successful install run
APP_INSTALLED=false

# ─── Database (Postgres) ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=<CHANGE_ME>
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=<CHANGE_ME>
DB_PREFIX=ak_
DB_SSLMODE=require

# ─── Cache / Session / Queue (Redis container) ────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# Separate DB indexes for isolation
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=0
REDIS_SESSION_DB=0

# ─── Mail (SendGrid) ──────────────────────────────────────────────────────────
MAIL_MAILER=sendgrid
SENDGRID_API_KEY=<CHANGE_ME>
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# ─── Trusted proxies (required for NPM to pass correct IP/protocol) ───────────
TRUSTED_PROXIES=*

# ─── First-boot install parameters ───────────────────────────────────────────
# Used by entrypoint.sh when APP_INSTALLED=false.
# Remove or ignore these once APP_INSTALLED=true.
COMPANY_NAME="My Company"
COMPANY_EMAIL=<CHANGE_ME>@your-domain.com
ADMIN_EMAIL=<CHANGE_ME>@your-domain.com
ADMIN_PASSWORD=<CHANGE_ME>

# ─── Feature flags ────────────────────────────────────────────────────────────
BROADCAST_DRIVER=log
FIREWALL_ENABLED=false
MODEL_CACHE_ENABLED=false

# ─── Filesystem (S3-compatible) ───────────────────────────
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=<CHANGE_ME>
AWS_SECRET_ACCESS_KEY=<CHANGE_ME>
AWS_DEFAULT_REGION=<CHANGE_ME>
AWS_BUCKET=<CHANGE_ME>
AWS_ENDPOINT=<CHANGE_ME>
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_VISIBILITY=<CHANGE_ME>
